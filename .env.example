# Copier ce fichier vers .env.local et renseigner les vraies valeurs.
# .env.local n'est jamais commité (cf. .gitignore).

# --- Général ---
# URL de base du site (sous-domaine à confirmer, cf. docs/etape-0-mvp-esta.md section 9)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# --- Supabase (projet dédié fenuasim-travel-mvp, isolé du Supabase FENUASIM principal) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clé service_role : ne JAMAIS exposer au client, uniquement dans les routes serveur / jobs.
SUPABASE_SERVICE_ROLE_KEY=

# --- Chiffrement applicatif passeport/MRZ (AES-256-GCM) ---
# 32 octets encodés en base64. Générer avec :
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Ne jamais commiter la valeur réelle. Procédure de rotation : docs/rotation-cle-chiffrement.md
PASSPORT_ENCRYPTION_KEY_V1=
# Version de clé courante utilisée pour les nouvelles écritures (cf. travelers.encryption_key_version)
PASSPORT_ENCRYPTION_KEY_CURRENT_VERSION=1

# --- Stripe (mode test au démarrage) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Brevo (emails transactionnels, Sprint 4) ---
BREVO_API_KEY=

# --- Microservice OCR (Fly.io, Sprint 2) ---
OCR_SERVICE_URL=
OCR_SERVICE_SHARED_SECRET=
